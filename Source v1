let isAnimating = false;
function showView(navEntry, direction = 'replace') {
  if (isAnimating) return;
  const stageEl = stage();
  const oldView = stageEl.querySelector('.view');
  const newView = buildView(navEntry);
  if (!newView) return;
  attachViewEvents(newView, navEntry);
  stageEl.appendChild(newView);

  if (direction === 'replace') {
    if (oldView) oldView.remove();
  } else {
    isAnimating = true;
    newView.classList.add(direction === 'forward' ? 'enter-right' : 'enter-left');
    // force reflow
    void newView.offsetWidth;
    requestAnimationFrame(() => {
      newView.classList.remove('enter-right', 'enter-left');
      if (oldView) oldView.classList.add(direction === 'forward' ? 'exit-left' : 'exit-right');
    });
    setTimeout(() => {
      if (oldView) oldView.remove();
      isAnimating = false;
    }, 360);
  }
  renderTopbar();
  renderBottombar();
}

function pushNav(entry) {
  state.nav.push(entry);
  showView(entry, 'forward');
}
function popNav() {
  if (state.nav.length <= 1) return;
  state.nav.pop();
  showView(currentNav(), 'back');
}

