  if (state.routine.length === 0) {
    html += `<div class="empty">No exercises yet. Tap parts of the body to add some.</div>`;
  } else {
    html += `<h3>Exercises</h3><div class="r-list">`;
    state.routine.forEach((id, idx) => {
      const ex = findEx(id);
      if (!ex) return;
      html += `
