// ============ STORAGE (localStorage version) ============
const STORAGE_PREFIX = 'training:';
function lsGet(key) {
  try { return localStorage.getItem(STORAGE_PREFIX + key); } catch(e) { return null; }
}
function lsSet(key, value) {
  try { localStorage.setItem(STORAGE_PREFIX + key, value); } catch(e) {}
}
async function loadState() {
  try {
    const cur = lsGet('current');
    if (cur) {
      const p = JSON.parse(cur);
      state.routineName = p.routineName || '';
      state.routine = p.routine || [];
    }
  } catch (e) {}
  try {
    const sv = lsGet('saved');
    if (sv) state.saved = JSON.parse(sv) || [];
  } catch (e) {}
  try {
    const md = lsGet('mode');
    if (md) state.mode = md === 'browse' ? 'browse' : 'build';
  } catch (e) {}
}
async function saveCurrent() {
  lsSet('current', JSON.stringify({ routineName: state.routineName, routine: state.routine }));
}
async function saveSaved() {
  lsSet('saved', JSON.stringify(state.saved));
}
async function saveMode() {
