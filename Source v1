// ============ HELPERS ============
const $ = sel => document.querySelector(sel);
const $$ = sel => document.querySelectorAll(sel);
const findEx = id => EXERCISES.find(e => e.id === id);

function getMuscleHits() {
  const c = {};
  ALL_MUSCLES.forEach(m => c[m] = 0);
  state.routine.forEach(id => {
    const ex = findEx(id);
    if (!ex) return;
    ex.primary.forEach(m => { c[m] = (c[m] || 0) + 2; });
    ex.secondary.forEach(m => { c[m] = (c[m] || 0) + 1; });
  });
  return c;
}
function computeFocus() {
  if (state.routine.length === 0) return '—';
  const h = getMuscleHits();
  const groups = {
    Push: h['Chest'] + h['Front Delts'] + h['Triceps'],
    Pull: h['Lats'] + h['Upper Back'] + h['Biceps'] + h['Rear Delts'] + h['Traps'],
    Legs: h['Quads'] + h['Hamstrings'] + h['Glutes'] + h['Calves'],
    Core: h['Core'] + h['Obliques']
  };
  const max = Object.entries(groups).reduce((a,b) => b[1] > a[1] ? b : a, ['—', 0]);
  return max[1] > 0 ? max[0] : '—';
}
function exercisesForMuscle(muscle, mode) {
  const all = EXERCISES.filter(e => e.primary.includes(muscle) || e.secondary.includes(muscle));
  if (mode === 'build') {
    return EXERCISES.filter(e => e.curatedFor && e.curatedFor.includes(muscle));
  }
  return all;
}
function exerciseCountFor(muscle, mode) {
  return exercisesForMuscle(muscle, mode).length;
}

function formatDate(ts) {
  const d = new Date(ts);
  return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
