    v.querySelectorAll('.muscle-tile').forEach(b => {
      b.addEventListener('click', () => pushNav({ view: 'muscle', key: b.dataset.muscle }));
    });
  } else if (navEntry.view === 'muscle') {
    v.querySelectorAll('.ex-card').forEach(c => {
