function toggleExercise(id) {
  const i = state.routine.indexOf(id);
  if (i >= 0) state.routine.splice(i, 1);
  else state.routine.push(id);
  saveCurrent();
  // re-render current view in place to update added states
  const stageEl = stage();
  const old = stageEl.querySelector('.view');
  const fresh = buildView(currentNav());
  attachViewEvents(fresh, currentNav());
  stageEl.appendChild(fresh);
  if (old) old.remove();
  renderBottombar();
  renderDrawer();
