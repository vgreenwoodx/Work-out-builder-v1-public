// ============ SVG RENDERING ============
function renderMiniBody(highlightedMuscles, size = 76) {
  // Build a small SVG with both front+back side by side, with given muscles highlighted
  const highSet = new Set(highlightedMuscles || []);
  function pathHighlight(name) {
    const base = name.replace(/ [LR]$/, '');
    return highSet.has(base);
  }
  let parts = '<svg viewBox="0 0 200 100" class="body-svg" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">';
  // Front
  parts += `<g transform="translate(0,0)">`;
  parts += `<path class="muscle-outline" d="${BODY_PATHS.silhouette}" transform="translate(0,-50) scale(1,0.55) translate(0,50)" />`;
  // Use a single scale group around silhouette
  parts += `</g>`;
  // Better approach: use full 100x200 viewbox, but two svgs side by side
  parts = `<svg viewBox="0 0 220 200" class="body-svg" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">`;
  // FRONT
  parts += `<g transform="translate(0,0)">`;
  parts += `<path class="muscle-outline" d="${BODY_PATHS.silhouette}" />`;
  for (const [name, d] of Object.entries(BODY_PATHS.front)) {
    const hit = pathHighlight(name);
    parts += `<path class="muscle ${hit ? 'hit-3' : ''}" d="${d}" />`;
  }
  parts += `</g>`;
  // BACK
  parts += `<g transform="translate(110,0)">`;
  parts += `<path class="muscle-outline" d="${BODY_PATHS.silhouette}" />`;
  for (const [name, d] of Object.entries(BODY_PATHS.back)) {
    const hit = pathHighlight(name);
    parts += `<path class="muscle ${hit ? 'hit-3' : ''}" d="${d}" />`;
  }
  parts += `</g>`;
  parts += `</svg>`;
  return parts;
}

function renderFullBodySVG(side, regionPaths) {
  // side: 'front' | 'back'
  const muscles = side === 'front' ? BODY_PATHS.front : BODY_PATHS.back;
  const hits = getMuscleHits();
  let svg = `<svg viewBox="0 0 100 200" class="body-svg" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">`;
  svg += `<path class="muscle-outline" d="${BODY_PATHS.silhouette}" />`;
  for (const [name, d] of Object.entries(muscles)) {
    const base = name.replace(/ [LR]$/, '');
    const c = hits[base] || 0;
    const cls = c >= 5 ? 'hit-3' : c >= 3 ? 'hit-2' : c >= 1 ? 'hit-1' : '';
    svg += `<path class="muscle ${cls}" data-muscle="${base}" d="${d}" />`;
  }
  // region overlays
  for (const [key, d] of Object.entries(regionPaths)) {
    svg += `<path class="region" data-region="${key}" d="${d}" />`;
  }
  svg += `</svg>`;
  return svg;
}

