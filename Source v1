            <button class="r-btn remove" data-r-act="remove" data-r-id="${id}">×</button>
          </div>
        </div>
      `;
    });
    html += `</div>`;
    // muscle bars
    html += `<h3>Muscle Coverage</h3><div class="muscle-bars">`;
    const sorted = [...ALL_MUSCLES].sort((a,b) => {
      const ha = hits[a] || 0, hb = hits[b] || 0;
      if (ha !== hb) return hb - ha;
      return a.localeCompare(b);
    });
    sorted.forEach(m => {
      const c = hits[m] || 0;
      const pct = c > 0 ? Math.max(8, (c / max) * 100) : 0;
      html += `
        <div class="m-row ${c > 0 ? 'hit' : ''}">
          <div class="name">${m}</div>
          <div class="m-bar"><div class="m-bar-fill" style="width:${pct}%; ${c === 0 ? 'background: var(--surface-2);' : ''}"></div></div>
          <div class="m-count">${c || ''}</div>
        </div>
      `;
    });
    html += `</div>`;
  }

  html += `<div class="drawer-actions">
    <button class="btn ghost danger" id="drawerClearBtn">Clear</button>
    <button class="btn primary" id="drawerSaveBtn" ${state.routine.length === 0 ? 'disabled' : ''}>Save Session</button>
  </div>`;

  if (state.saved.length > 0) {
    html += `<h3>Saved Sessions</h3><div class="saved-list">`;
    state.saved.slice().reverse().forEach(s => {
      html += `
        <div class="saved-item">
          <div class="saved-info">
            <div class="saved-name">${s.name}</div>
            <div class="saved-meta">${s.ids.length} exercise${s.ids.length===1?'':'s'} · saved ${formatDate(s.savedAt)}</div>
          </div>
          <div class="r-actions">
            <button class="btn ghost" data-saved-act="load" data-saved-id="${s.id}">Load</button>
            <button class="r-btn remove" data-saved-act="delete" data-saved-id="${s.id}">×</button>
          </div>
        </div>
      `;
    });
    html += `</div>`;
  }

  body.innerHTML = html;

  // wire events
  body.querySelectorAll('[data-r-act]').forEach(b => {
    b.addEventListener('click', () => {
      const act = b.dataset.rAct;
      if (act === 'remove') {
        toggleExercise(b.dataset.rId);
      } else {
        const idx = parseInt(b.dataset.rIdx, 10);
        const dir = act === 'up' ? -1 : 1;
        const newIdx = idx + dir;
        if (newIdx < 0 || newIdx >= state.routine.length) return;
        const [item] = state.routine.splice(idx, 1);
        state.routine.splice(newIdx, 0, item);
        saveCurrent();
        renderDrawer();
        // also refresh main view since order doesn't affect cards, but stats might
      }
    });
  });
  const clearBtn = body.querySelector('#drawerClearBtn');
  if (clearBtn) clearBtn.addEventListener('click', clearRoutine);
  const saveBtn = body.querySelector('#drawerSaveBtn');
  if (saveBtn) saveBtn.addEventListener('click', saveSession);
  body.querySelectorAll('[data-saved-act]').forEach(b => {
    const id = b.dataset.savedId;
    b.addEventListener('click', () => {
      if (b.dataset.savedAct === 'load') loadSession(id);
      else deleteSession(id);
    });
  });
}

function openDrawer() {
  state.drawerOpen = true;
  $('#drawer').classList.add('show');
  $('#drawerBg').classList.add('show');
  renderDrawer();
}
function closeDrawer() {
  state.drawerOpen = false;
  $('#drawer').classList.remove('show');
  $('#drawerBg').classList.remove('show');
}

function clearRoutine() {
  if (state.routine.length === 0) return;
  showModal({
    title: 'Clear Session?',
    text: 'This will remove all exercises from your current session.',
    okLabel: 'Clear',
    onOk: () => {
      state.routine = [];
      state.routineName = '';
      $('#routineName').value = '';
      saveCurrent();
      renderBottombar();
      renderDrawer();
      if (currentNav().view !== 'home') showView(currentNav(), 'replace');
      // refresh home body coverage if visible
      if (currentNav().view === 'home') showView(currentNav(), 'replace');
      toast('Session cleared');
    }
  });
}

function saveSession() {
  if (state.routine.length === 0) return;
  const defaultName = state.routineName.trim() || `Session ${state.saved.length + 1}`;
  showModal({
    title: 'Save Session',
    text: 'Name this routine to save it.',
    input: defaultName,
    okLabel: 'Save',
    onOk: (name) => {
      const finalName = (name || '').trim() || defaultName;
      const session = {
        id: 'sess-' + Date.now(),
        name: finalName,
        ids: [...state.routine],
        savedAt: Date.now()
      };
      state.saved.push(session);
      saveSaved();
      renderDrawer();
      toast(`"${finalName}" saved`);
    }
  });
}

function loadSession(id) {
  const s = state.saved.find(x => x.id === id);
  if (!s) return;
  state.routine = [...s.ids];
  state.routineName = s.name;
  $('#routineName').value = s.name;
  saveCurrent();
  renderBottombar();
  renderDrawer();
  if (currentNav().view !== 'home') showView(currentNav(), 'replace');
  else showView(currentNav(), 'replace');
  toast(`Loaded "${s.name}"`);
}
function deleteSession(id) {
  const s = state.saved.find(x => x.id === id);
  if (!s) return;
  showModal({
    title: 'Delete Session?',
    text: `Remove "${s.name}" from saved sessions?`,
    okLabel: 'Delete',
    onOk: () => {
      state.saved = state.saved.filter(x => x.id !== id);
      saveSaved();
      renderDrawer();
      toast('Deleted');
    }
  });
}

// ============ MODAL & TOAST ============
let toastTimeout;
function toast(msg) {
  const el = $('#toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => el.classList.remove('show'), 1800);
}

function showModal({ title, text, input, okLabel, onOk }) {
  $('#modalTitle').textContent = title;
  $('#modalText').textContent = text;
  $('#modalOk').textContent = okLabel || 'Confirm';
  const inp = $('#modalInput');
  if (input !== undefined) {
    inp.style.display = 'block';
    inp.value = input;
    setTimeout(() => inp.focus(), 60);
  } else {
    inp.style.display = 'none';
  }
  $('#modalBg').classList.add('show');

  const handleOk = () => { cleanup(); onOk(input !== undefined ? inp.value : undefined); };
  const handleCancel = () => cleanup();
  const handleKey = (e) => {
    if (e.key === 'Enter') handleOk();
    if (e.key === 'Escape') handleCancel();
  };
  function cleanup() {
    $('#modalBg').classList.remove('show');
    $('#modalOk').removeEventListener('click', handleOk);
    $('#modalCancel').removeEventListener('click', handleCancel);
    document.removeEventListener('keydown', handleKey);
  }
  $('#modalOk').addEventListener('click', handleOk);
  $('#modalCancel').addEventListener('click', handleCancel);
  document.addEventListener('keydown', handleKey);
}

// ============ EVENTS ============
$('#backBtn').addEventListener('click', popNav);
$('#modeBuild').addEventListener('click', () => setMode('build'));
$('#modeBrowse').addEventListener('click', () => setMode('browse'));
$('#routineBtn').addEventListener('click', openDrawer);
$('#drawerBg').addEventListener('click', closeDrawer);
$('#drawerHandle').addEventListener('click', closeDrawer);
$('#routineName').addEventListener('input', (e) => {
  state.routineName = e.target.value;
  saveCurrent();
  renderBottombar();
});
$('#modalBg').addEventListener('click', (e) => {
  if (e.target.id === 'modalBg') $('#modalCancel').click();
});

// drawer drag-to-close
(() => {
  let startY = 0, dragging = false, currentY = 0;
  const drawer = $('#drawer');
  const handle = $('#drawerHandle');
  handle.addEventListener('touchstart', e => {
    dragging = true; startY = e.touches[0].clientY; currentY = 0;
    drawer.style.transition = 'none';
  });
  handle.addEventListener('touchmove', e => {
    if (!dragging) return;
    currentY = Math.max(0, e.touches[0].clientY - startY);
    drawer.style.transform = `translateY(${currentY}px)`;
  });
  handle.addEventListener('touchend', () => {
    if (!dragging) return;
    dragging = false;
    drawer.style.transition = '';
    drawer.style.transform = '';
    if (currentY > 80) closeDrawer();
  });
})();

// ============ INIT ============
(async () => {
  await loadState();
  $('#modeBuild').classList.toggle('active', state.mode === 'build');
  $('#modeBrowse').classList.toggle('active', state.mode === 'browse');
  showView({ view: 'home' }, 'replace');
  renderTopbar();
  renderBottombar();
})();
</script>

</body>
