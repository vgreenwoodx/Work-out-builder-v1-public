<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no">
<title>Training Builder</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Fraunces:opsz,wght@9..144,300;9..144,500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0c0b09;
    --bg-2: #15130f;
    --surface: #1c1a16;
    --surface-2: #232019;
    --surface-3: #2a2620;
    --line: #2b271f;
    --line-2: #3a3528;
    --ink: #f4ede0;
    --ink-dim: #a39e90;
    --ink-mute: #6e6a5e;
    --accent: #d4ff3a;
    --accent-2: #ff6a3d;
    --hot: #ff3a3a;
    --radius: 14px;
    --radius-sm: 10px;
    --topbar-h: 60px;
    --bottombar-h: 72px;
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { height: 100%; overflow: hidden; }
  body {
  font-family: ‘DM Sans’, system-ui, sans-serif;
  background: var(–bg);
  color: var(–ink);
  font-size: 15px;
  line-height: 1.45;
  overscroll-behavior: none;
  background-image:
  radial-gradient(ellipse 80% 60% at 0% 0%, rgba(212,255,58,0.04), transparent 60%),
  radial-gradient(ellipse 60% 50% at 100% 100%, rgba(255,106,61,0.03), transparent 60%);
  user-select: none;
  -webkit-user-select: none;
  }
  button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
  input { font: inherit; color: inherit; background: none; border: none; outline: none; }
  input::placeholder { color: var(–ink-mute); }

.app {
height: 100dvh;
display: grid;
grid-template-rows: var(–topbar-h) 1fr var(–bottombar-h);
overflow: hidden;
position: relative;
}

/* TOP BAR */
.topbar {
border-bottom: 1px solid var(–line);
padding: 0 18px;
display: flex;
align-items: center;
gap: 12px;
background: var(–bg);
z-index: 10;
}
.back-btn {
width: 40px;
height: 40px;
border-radius: 50%;
border: 1px solid var(–line);
background: var(–surface);
color: var(–ink);
font-size: 18px;
display: flex;
align-items: center;
justify-content: center;
transition: all .15s;
flex-shrink: 0;
}
.back-btn:active { transform: scale(0.92); }
.back-btn.hidden { visibility: hidden; }
.topbar-title {
flex: 1;
min-width: 0;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
letter-spacing: 0.06em;
line-height: 1;
display: flex;
align-items: baseline;
gap: 8px;
}
.topbar-title .dot { color: var(–accent); }
.topbar-title .sub {
font-family: ‘Fraunces’, serif;
font-style: italic;
font-weight: 300;
font-size: 13px;
color: var(–ink-dim);
letter-spacing: 0.02em;
}
.mode-switch {
display: flex;
background: var(–surface);
border: 1px solid var(–line);
border-radius: 999px;
padding: 3px;
flex-shrink: 0;
}
.mode-switch button {
padding: 6px 14px;
border-radius: 999px;
font-size: 11px;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–ink-dim);
font-weight: 600;
transition: all .2s;
}
.mode-switch button.active {
background: var(–ink);
color: var(–bg);
}

/* BOTTOM BAR */
.bottombar {
border-top: 1px solid var(–line);
padding: 0 18px;
display: flex;
align-items: center;
gap: 12px;
background: var(–bg);
z-index: 10;
}
.routine-pill {
flex: 1;
height: 48px;
background: var(–surface);
border: 1px solid var(–line);
border-radius: 999px;
display: flex;
align-items: center;
gap: 12px;
padding: 0 18px 0 6px;
transition: all .2s;
}
.routine-pill:active { transform: scale(0.99); }
.routine-pill .badge {
width: 36px;
height: 36px;
border-radius: 50%;
background: var(–accent);
color: #1a1a0a;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 16px;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}
.routine-pill .badge.empty { background: var(–surface-3); color: var(–ink-mute); }
.routine-pill .label {
flex: 1;
text-align: left;
min-width: 0;
}
.routine-pill .label .name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 17px;
letter-spacing: 0.04em;
line-height: 1;
margin-bottom: 2px;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}
.routine-pill .label .meta {
font-size: 11px;
color: var(–ink-dim);
letter-spacing: 0.04em;
}
.routine-pill .arrow {
color: var(–ink-mute);
font-size: 14px;
}

/* VIEW STAGE */
.stage {
position: relative;
overflow: hidden;
min-height: 0;
}
.view {
position: absolute;
inset: 0;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
transition: transform .35s cubic-bezier(.4,0,.2,1), opacity .25s;
background: var(–bg);
}
.view::-webkit-scrollbar { width: 6px; }
.view::-webkit-scrollbar-thumb { background: var(–line-2); border-radius: 3px; }
.view.exit-left { transform: translateX(-30%); opacity: 0; pointer-events: none; }
.view.enter-right { transform: translateX(100%); opacity: 0; }
.view.exit-right { transform: translateX(30%); opacity: 0; pointer-events: none; }
.view.enter-left { transform: translateX(-100%); opacity: 0; }

/* HOME (BODY) VIEW */
.body-stage {
height: 100%;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
padding: 16px;
perspective: 1200px;
}
.body-headline {
text-align: center;
margin-bottom: 8px;
font-family: ‘Fraunces’, serif;
font-style: italic;
font-weight: 300;
color: var(–ink-dim);
font-size: 14px;
letter-spacing: 0.02em;
}
.body-headline strong { color: var(–ink); font-weight: 500; font-style: normal; font-family: ‘Bebas Neue’, sans-serif; letter-spacing: 0.08em; font-size: 16px; }
.body-rotator-wrap {
flex: 1;
display: flex;
align-items: center;
justify-content: center;
width: 100%;
position: relative;
min-height: 0;
}
.body-rotator {
width: min(280px, 60vh);
height: min(560px, 90%);
max-height: 100%;
position: relative;
transform-style: preserve-3d;
transition: transform .5s cubic-bezier(.4,0,.2,1);
touch-action: none;
}
.body-rotator.dragging { transition: none; }
.body-face {
position: absolute;
inset: 0;
backface-visibility: hidden;
display: flex;
align-items: center;
justify-content: center;
}
.body-face.back { transform: rotateY(180deg); }
.body-face svg {
width: 100%;
height: 100%;
display: block;
}

/* BODY SVG MUSCLES */
.body-svg .muscle-outline {
fill: var(–bg-2);
stroke: var(–line-2);
stroke-width: 0.8;
}
.body-svg .muscle {
fill: var(–surface);
stroke: var(–line-2);
stroke-width: 0.5;
transition: fill .35s ease, stroke .35s ease;
pointer-events: none;
}
.body-svg .muscle.hit-1 { fill: rgba(212,255,58,0.22); stroke: rgba(212,255,58,0.4); }
.body-svg .muscle.hit-2 { fill: rgba(212,255,58,0.5); stroke: rgba(212,255,58,0.65); }
.body-svg .muscle.hit-3 { fill: var(–accent); stroke: var(–accent); }

/* CLICKABLE REGION OVERLAYS */
.body-svg .region {
fill: rgba(255,255,255,0.001);
stroke: rgba(212,255,58,0);
stroke-width: 1.2;
cursor: pointer;
transition: fill .2s, stroke .2s;
}
.body-svg .region:hover,
.body-svg .region.active {
fill: rgba(212,255,58,0.08);
stroke: rgba(212,255,58,0.6);
}

.body-controls {
display: flex;
gap: 8px;
margin-top: 12px;
align-items: center;
}
.face-btn {
padding: 8px 16px;
border-radius: 999px;
border: 1px solid var(–line);
background: var(–surface);
color: var(–ink-dim);
font-size: 11px;
letter-spacing: 0.12em;
text-transform: uppercase;
font-weight: 600;
transition: all .2s;
}
.face-btn.active {
background: var(–ink);
color: var(–bg);
border-color: var(–ink);
}
.rotate-hint {
font-size: 11px;
color: var(–ink-mute);
letter-spacing: 0.08em;
text-transform: uppercase;
margin-top: 8px;
font-family: ‘Fraunces’, serif;
font-style: italic;
text-transform: none;
letter-spacing: 0;
font-size: 12px;
}

/* REGION VIEW */
.region-view {
padding: 20px;
padding-bottom: 40px;
}
.region-intro {
text-align: center;
margin-bottom: 24px;
padding: 0 8px;
}
.region-intro h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 42px;
letter-spacing: 0.06em;
line-height: 1;
margin-bottom: 6px;
}
.region-intro p {
font-family: ‘Fraunces’, serif;
font-style: italic;
font-weight: 300;
color: var(–ink-dim);
font-size: 14px;
}
.muscle-tiles {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
gap: 12px;
max-width: 720px;
margin: 0 auto;
}
.muscle-tile {
background: var(–surface);
border: 1px solid var(–line);
border-radius: var(–radius);
padding: 16px;
display: grid;
grid-template-columns: 70px 1fr auto;
align-items: center;
gap: 14px;
transition: all .2s;
cursor: pointer;
text-align: left;
color: inherit;
}
.muscle-tile:active { transform: scale(0.99); }
.muscle-tile:hover { border-color: var(–line-2); background: var(–surface-2); }
.muscle-tile .thumb {
width: 70px;
height: 70px;
background: var(–bg);
border: 1px solid var(–line);
border-radius: var(–radius-sm);
display: flex;
align-items: center;
justify-content: center;
}
.muscle-tile .thumb svg {
width: 100%;
height: 100%;
}
.muscle-tile .info { min-width: 0; }
.muscle-tile .info .name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
letter-spacing: 0.05em;
line-height: 1.1;
margin-bottom: 4px;
}
.muscle-tile .info .meta {
font-size: 12px;
color: var(–ink-dim);
letter-spacing: 0.02em;
}
.muscle-tile .info .meta .added {
color: var(–accent);
font-weight: 600;
}
.muscle-tile .arrow {
color: var(–ink-mute);
font-size: 20px;
padding: 0 4px;
}

/* MUSCLE / EXERCISE LIST VIEW */
.muscle-view {
padding: 20px;
padding-bottom: 40px;
}
.muscle-intro {
text-align: center;
margin-bottom: 24px;
}
.muscle-intro h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 42px;
letter-spacing: 0.06em;
line-height: 1;
margin-bottom: 4px;
}
.muscle-intro .mode-tag {
display: inline-flex;
align-items: center;
gap: 6px;
padding: 4px 10px;
background: var(–surface);
border: 1px solid var(–line);
border-radius: 999px;
font-size: 11px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–ink-dim);
font-weight: 600;
margin-top: 8px;
}
.muscle-intro .mode-tag .dot {
width: 6px;
height: 6px;
border-radius: 50%;
background: var(–accent);
}
.exercise-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
gap: 10px;
max-width: 760px;
margin: 0 auto;
}
.ex-card {
background: var(–surface);
border: 1px solid var(–line);
border-radius: var(–radius);
padding: 12px;
display: grid;
grid-template-columns: 76px 1fr auto;
gap: 14px;
align-items: center;
transition: all .2s;
cursor: pointer;
text-align: left;
}
.ex-card:active { transform: scale(0.99); }
.ex-card.added {
background: var(–surface-2);
border-color: var(–line-2);
}
.ex-card .thumb {
width: 76px;
height: 76px;
background: var(–bg);
border: 1px solid var(–line);
border-radius: var(–radius-sm);
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}
.ex-card .thumb svg { width: 100%; height: 100%; }
.ex-card .body { min-width: 0; }
.ex-card .body .name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 20px;
letter-spacing: 0.04em;
line-height: 1.1;
margin-bottom: 4px;
}
.ex-card.added .body .name { color: var(–accent); }
.ex-card .body .desc {
font-size: 13px;
color: var(–ink-dim);
line-height: 1.35;
margin-bottom: 6px;
}
.ex-card .body .tags {
display: flex;
gap: 6px;
flex-wrap: wrap;
}
.ex-card .body .tag {
font-size: 10px;
text-transform: uppercase;
letter-spacing: 0.1em;
color: var(–ink-mute);
padding: 2px 8px;
background: var(–bg);
border-radius: 999px;
border: 1px solid var(–line);
font-weight: 500;
}
.ex-card .add-btn {
width: 40px;
height: 40px;
border-radius: 50%;
background: var(–bg);
border: 1px solid var(–line-2);
color: var(–ink-dim);
font-size: 22px;
line-height: 1;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
transition: all .2s;
}
.ex-card.added .add-btn {
background: var(–accent);
color: #1a1a0a;
border-color: var(–accent);
font-weight: 600;
}

.empty {
padding: 60px 20px;
text-align: center;
color: var(–ink-mute);
font-family: ‘Fraunces’, serif;
font-style: italic;
font-weight: 300;
font-size: 15px;
}

/* ROUTINE DRAWER */
.drawer-bg {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.6);
backdrop-filter: blur(6px);
opacity: 0;
pointer-events: none;
transition: opacity .3s;
z-index: 50;
}
.drawer-bg.show { opacity: 1; pointer-events: auto; }
.drawer {
position: fixed;
bottom: 0;
left: 0;
right: 0;
max-height: 85vh;
background: var(–bg-2);
border-top: 1px solid var(–line);
border-radius: 20px 20px 0 0;
transform: translateY(100%);
transition: transform .35s cubic-bezier(.4,0,.2,1);
z-index: 60;
display: flex;
flex-direction: column;
}
.drawer.show { transform: translateY(0); }
.drawer-handle {
padding: 12px;
display: flex;
justify-content: center;
cursor: grab;
}
.drawer-handle .bar {
width: 44px;
height: 4px;
background: var(–line-2);
border-radius: 2px;
}
.drawer-head {
padding: 0 22px 14px;
display: flex;
align-items: center;
gap: 12px;
border-bottom: 1px solid var(–line);
}
.drawer-head h2 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 24px;
letter-spacing: 0.06em;
line-height: 1;
flex-shrink: 0;
}
.drawer-name-input {
flex: 1;
min-width: 0;
padding: 8px 0;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 18px;
letter-spacing: 0.04em;
color: var(–ink);
border-bottom: 1px solid transparent;
transition: border-color .2s;
}
.drawer-name-input:focus { border-bottom-color: var(–line-2); }
.drawer-body {
flex: 1;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
padding: 18px 22px 24px;
}
.drawer-body::-webkit-scrollbar { width: 6px; }
.drawer-body::-webkit-scrollbar-thumb { background: var(–line-2); border-radius: 3px; }

.stat-row {
display: flex;
gap: 8px;
margin-bottom: 18px;
}
.stat-row .stat {
flex: 1;
padding: 12px 14px;
background: var(–surface);
border: 1px solid var(–line);
border-radius: var(–radius-sm);
}
.stat .n {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 26px;
line-height: 1;
color: var(–accent);
}
.stat .l {
font-size: 10.5px;
text-transform: uppercase;
letter-spacing: 0.12em;
color: var(–ink-mute);
margin-top: 4px;
}

.drawer h3 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 16px;
letter-spacing: 0.1em;
color: var(–ink-dim);
font-weight: 400;
margin: 18px 0 10px;
}
.drawer h3:first-child { margin-top: 0; }

.r-list { display: flex; flex-direction: column; gap: 6px; }
.r-item {
display: grid;
grid-template-columns: 28px 1fr auto;
gap: 10px;
align-items: center;
padding: 10px 12px;
background: var(–surface);
border: 1px solid var(–line);
border-radius: var(–radius-sm);
}
.r-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
color: var(–accent);
line-height: 1;
text-align: center;
}
.r-info { min-width: 0; }
.r-name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 17px;
letter-spacing: 0.04em;
line-height: 1.1;
}
.r-muscles {
font-size: 11px;
color: var(–ink-dim);
margin-top: 2px;
}
.r-actions { display: flex; gap: 2px; }
.r-btn {
width: 32px;
height: 32px;
border-radius: var(–radius-sm);
color: var(–ink-mute);
font-size: 14px;
display: flex;
align-items: center;
justify-content: center;
}
.r-btn:active { background: var(–bg); color: var(–ink); }
.r-btn.remove:active { color: var(–hot); }

.drawer-actions {
display: flex;
gap: 8px;
margin-top: 16px;
}
.btn {
padding: 11px 18px;
border-radius: var(–radius-sm);
font-weight: 600;
font-size: 13px;
letter-spacing: 0.04em;
background: var(–surface);
border: 1px solid var(–line);
transition: all .15s;
}
.btn:active { transform: scale(0.97); }
.btn.primary {
background: var(–accent);
color: #1a1a0a;
border-color: var(–accent);
flex: 1;
}
.btn.primary:disabled { opacity: 0.35; }
.btn.ghost { background: transparent; }
.btn.danger { color: var(–hot); border-color: rgba(255,58,58,0.3); }

.muscle-bars { display: flex; flex-direction: column; gap: 4px; }
.m-row {
display: grid;
grid-template-columns: 100px 1fr 24px;
gap: 10px;
align-items: center;
padding: 4px 0;
}
.m-row .name {
font-size: 11.5px;
text-transform: uppercase;
letter-spacing: 0.08em;
color: var(–ink-dim);
}
.m-row.hit .name { color: var(–ink); }
.m-bar {
height: 5px;
background: var(–surface);
border-radius: 3px;
overflow: hidden;
position: relative;
}
.m-bar-fill {
position: absolute;
inset: 0 auto 0 0;
background: linear-gradient(90deg, var(–accent) 0%, var(–accent-2) 100%);
border-radius: 3px;
transition: width .35s cubic-bezier(.2,.8,.3,1);
}
.m-count {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 14px;
color: var(–ink-dim);
text-align: right;
line-height: 1;
}
.m-row.hit .m-count { color: var(–accent); }

.saved-list { display: flex; flex-direction: column; gap: 6px; }
.saved-item {
padding: 11px 14px;
background: var(–surface);
border: 1px solid var(–line);
border-radius: var(–radius-sm);
display: flex;
align-items: center;
justify-content: space-between;
gap: 10px;
}
.saved-info { min-width: 0; flex: 1; }
.saved-name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 16px;
letter-spacing: 0.04em;
line-height: 1.1;
}
.saved-meta {
font-size: 11px;
color: var(–ink-mute);
margin-top: 3px;
}

/* TOAST */
.toast {
position: fixed;
bottom: calc(var(–bottombar-h) + 16px);
left: 50%;
transform: translateX(-50%) translateY(20px);
background: var(–ink);
color: var(–bg);
padding: 10px 18px;
border-radius: 999px;
font-size: 13px;
font-weight: 500;
letter-spacing: 0.02em;
opacity: 0;
pointer-events: none;
transition: all .25s;
z-index: 200;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* MODAL */
.modal-bg {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.7);
backdrop-filter: blur(6px);
display: none;
align-items: center;
justify-content: center;
z-index: 300;
padding: 20px;
}
.modal-bg.show { display: flex; }
.modal {
background: var(–bg-2);
border: 1px solid var(–line);
border-radius: var(–radius);
padding: 24px;
max-width: 380px;
width: 100%;
}
.modal h3 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
letter-spacing: 0.06em;
margin-bottom: 8px;
font-weight: 400;
color: var(–ink);
}
.modal p {
color: var(–ink-dim);
font-size: 14px;
margin-bottom: 18px;
}
.modal input {
width: 100%;
padding: 12px 14px;
background: var(–surface);
border: 1px solid var(–line);
border-radius: var(–radius-sm);
font-size: 15px;
margin-bottom: 18px;
}
.modal input:focus { border-color: var(–accent); }
