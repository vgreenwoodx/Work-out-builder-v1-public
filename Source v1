// ============ BODY ROTATION ============
function setupBodyRotation(v) {
  const rot = v.querySelector('#bodyRotator');
  if (!rot) return;
  let dragging = false;
  let startX = 0;
  let startAngle = 0;
  let moved = false;
  const threshold = 8;

  const onStart = (clientX) => {
    dragging = true;
    moved = false;
    startX = clientX;
    startAngle = state.bodyAngle;
    rot.classList.add('dragging');
  };
  const onMove = (clientX) => {
    if (!dragging) return;
    const dx = clientX - startX;
    if (Math.abs(dx) > threshold) moved = true;
    const angle = startAngle + dx * 0.6;
    rot.style.transform = `rotateY(${angle}deg)`;
    state.bodyAngle = angle;
  };
  const onEnd = () => {
    if (!dragging) return;
    dragging = false;
    rot.classList.remove('dragging');
    // snap to nearest 180
    const norm = ((state.bodyAngle % 360) + 360) % 360;
    const target = norm < 90 || norm > 270 ? 0 : 180;
    state.bodyAngle = target;
    rot.style.transform = `rotateY(${target}deg)`;
    document.querySelectorAll('.face-btn').forEach(b => {
      const isFront = b.dataset.face === 'front';
      b.classList.toggle('active', (target === 0 && isFront) || (target === 180 && !isFront));
    });
    if (moved) {
      // suppress next region click after a drag
      v.dataset.suppressClick = '1';
      setTimeout(() => { delete v.dataset.suppressClick; }, 50);
    }
  };

  rot.addEventListener('touchstart', e => onStart(e.touches[0].clientX), { passive: true });
  rot.addEventListener('touchmove',  e => onMove(e.touches[0].clientX), { passive: true });
  rot.addEventListener('touchend',   onEnd);
  rot.addEventListener('mousedown',  e => { onStart(e.clientX); e.preventDefault(); });
  window.addEventListener('mousemove', e => onMove(e.clientX));
  window.addEventListener('mouseup',   onEnd);

  // Region clicks: ignore if drag happened
  rot.querySelectorAll('.region').forEach(p => {
    p.addEventListener('click', (e) => {
      if (v.dataset.suppressClick) {
        e.stopPropagation();
        e.preventDefault();
        return;
      }
    }, true);
  });
}

